# Database (required)
# PostgreSQL connection string — use Neon, Supabase, or Vercel Postgres in production
DATABASE_URL=postgres://taskuser:taskpass@localhost:5432/taskmanager?sslmode=disable

# Auth (required in production)
JWT_SECRET=change-this-to-a-long-random-string

# Frontend — only needed for local dev when API runs separately
# On Vercel, Go functions are served at /api automatically
API_URL=http://localhost:8080

# Go API local server port (optional, default 8080). Do not set PORT — Next.js reads that too.
API_PORT=8080
