FROM golang:1.22-alpine AS builder
WORKDIR /app

# Module metadata (both root and api — root go.sum is required for the replace build)
COPY go.mod go.sum ./
COPY api/go.mod api/go.sum ./api/

RUN go mod download

COPY api/ ./api/
COPY pkg/ ./pkg/
COPY cmd/ ./cmd/

RUN CGO_ENABLED=0 go build -o server ./cmd/server

FROM alpine:3.20
RUN apk add --no-cache ca-certificates
WORKDIR /app
COPY --from=builder /app/server .
EXPOSE 8080
CMD ["./server"]
